# ─── Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://comparateurcrm.fr
GOOGLE_SITE_VERIFICATION=

# ─── Matomo (mesure d'audience) ──────────────────────────────────────
# URL de ton instance Matomo, AVEC le slash final.
# Tu analyses déjà 2 autres sites : crée un nouveau "site" dans Matomo
# (Administration → Sites web → Ajouter), récupère son ID, et mets-le ici.
NEXT_PUBLIC_MATOMO_URL=https://analytics.tondomaine.fr/
NEXT_PUBLIC_MATOMO_SITE_ID=

# ─── Google Search Console (extraction de données) ───────────────────
# Réutilise la clé du service account d'indexation. Chemin par défaut :
# ~/.config/comparateurcrm/google-indexing.json
# GOOGLE_INDEXING_KEY_PATH=/chemin/vers/google-indexing.json

# ─── Affiliation (à remplir quand les programmes sont validés) ───────
# AFFILIATE_HUBSPOT_ID=
# AFFILIATE_PIPEDRIVE_ID=

# ─── Newsletter (ESP — quand branché) ────────────────────────────────
# NEWSLETTER_API_KEY=
